{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@app/*": ["app/*"],

      "@assets/*": ["assets/*"],
      "@img/*": ["assets/images/*"],
      "@audio/*": ["assets/audio/*"],
      "@video/*": ["assets/video/*"],

      "@lib/*": ["src/lib/*"],
      "@cmp/*": ["src/components/*"],
      "@stylez": ["src/stylez/index.ts"],
      "@stylez/*": ["src/stylez/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
